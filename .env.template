# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=multi_agent

# 应用环境
APP_ENV=production

# API配置
API_BASE_URL=http://localhost:8000

# 知识库API密钥（如果需要）
# KNOWLEDGE_API_KEY=your_api_key_here

# Dify集成配置（如果需要）
# OPENAI_API_BASE=http://your-dify-server/v1
# OPENAI_API_KEY=your_dify_api_key

# 日志级别
LOG_LEVEL=INFO

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_TYPE=memory

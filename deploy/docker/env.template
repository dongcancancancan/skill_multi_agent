# 多智能体金融助手项目 - 环境变量配置模板
# 复制此文件为 .env 并根据实际情况修改配置

# ==================== 应用配置 ====================
APP_ENV=development
APP_DEBUG=true

# ==================== 数据库配置 ====================
# MySQL Docker 容器配置
MYSQL_ROOT_PASSWORD=Password         # MySQL root 密码
MYSQL_DATABASE=multi_agent           # 自动创建的数据库名
MYSQL_APP_USER=multi_agent_user      # 应用程序连接用户
MYSQL_APP_PASSWORD=Password          # 应用程序连接密码
MYSQL_PORT=3306                      # MySQL 端口

# MySQL 应用程序连接配置
MYSQL_HOST=localhost                 # 应用连接的主机（Docker外部）
MYSQL_USER=root                      # 应用连接使用的用户（通常是root）
MYSQL_PASSWORD=Password              # 应用连接使用的密码

# ==================== 缓存配置 ====================
# Redis 配置（会话管理和缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # 可选，如果Redis设置了密码

# ==================== AI 服务配置 ====================
# OpenAI API 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Anthropic API 配置
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangSmith 配置（可选，用于调试和监控）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=multi-agent-financial-assistant

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== API 服务配置 ====================
# FastAPI 配置
API_HOST=0.0.0.0
API_PORT=8000

# Chainlit 配置
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8001

# ==================== 金融数据源配置 ====================
# AkShare 金融数据源配置
AKSHARE_TOKEN=your_akshare_token_here

# ==================== 安全配置 ====================
# JWT 密钥（如果使用身份验证）
JWT_SECRET_KEY=your_jwt_secret_key_here

# ==================== 外部服务配置 ====================
# 外部金融服务API（模拟服务器）
EXTERNAL_API_BASE_URL=http://localhost:8082
EXTERNAL_API_TIMEOUT=30

# ==================== 性能配置 ====================
# 并发配置
MAX_CONCURRENT_TOOLS=8
TOOL_TIMEOUT=160
REQUEST_TIMEOUT=120

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600
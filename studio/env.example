# ============================================================
# LangGraph Studio 环境配置模板
# ============================================================
#
# 使用说明:
# 1. 根据目标环境复制对应的模板文件:
#    cp .env.sit.template .env.sit
#    cp .env.uat.template .env.uat
#
# 2. 在复制的文件中填写实际的敏感信息（API密钥等）
#
# 3. 使用切换脚本在不同环境间切换:
#    ./switch_env.sh sit   # 切换到SIT
#    ./switch_env.sh uat   # 切换到UAT
#
# 4. 重启 LangGraph Studio 使新配置生效
#

# LangSmith Configuration - For tracing and monitoring
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=multi-agent-financial-assistant

# LLM Configuration - Required by the application
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=your_llm_api_base_here
LLM_MODEL_NAME=your_model_name_here

# Environment Identifier - 环境标识 (sit/uat/prod)
APP_ENV=sit

# Knowledge Base Configuration - 知识库配置
# 注意: 不同环境的API地址和密钥不同，请参考 .env.sit.template 和 .env.uat.template
KNOWLEDGE_API_BASE=your_knowledge_api_base_here
KNOWLEDGE_API_KEY=your_knowledge_api_key_here
